# ===========================
# React Native Expo .gitignore
# ===========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native builds
android/app/build/
android/.gradle/
android/local.properties
android/captures/
android/keystores/
ios/build/
ios/Pods/
ios/DerivedData/
*.apk
*.aab
*.ipa
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision
*.xcworkspace

# Environment variables (IMPORTANT: never commit secrets!)
.env
.env.local
.env.development
.env.production
.env.*

# Metro bundler cache
.metro-health-check*
.cache/

# Testing
coverage/
.jest/

# TypeScript
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
tmp/
temp/
*.tmp
*.temp